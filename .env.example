# OpenAI official Images API (or any OpenAI-compatible relay you trust)
# Base URL may be either the service root or its /v1 endpoint.
# Examples:
#   OPENAI_BASE_URL=https://api.openai.com
#   OPENAI_BASE_URL=https://apihk.unifyllm.top
#   OPENAI_BASE_URL=https://apihk.unifyllm.top/v1
OPENAI_BASE_URL=https://api.openai.com
OPENAI_API_KEY=sk-your-key-here

# Model name (default: gpt-image-2)
GPT_IMAGE_MODEL_NAME=gpt-image-2

# Image quality: low / medium / high / auto
GPT_IMAGE_QUALITY=high

# Endpoint mode: auto / images / chat
# - auto tries /v1/images/generations first, then falls back to chat.
# - For apihk.unifyllm.top, public pricing marks gpt-image-2 as image-generation,
#   so `images` is the strictest setting for the normal built-in-style workflow.
# - For template-strict/reference-image workflows on relays that expose image
#   generation through chat, use the relay's chat-capable image model if needed.
GPT_IMAGE_ENDPOINT=auto

# -- Vision provider (OPTIONAL: only required for template-clone mode) --------
# Used to analyse user-supplied .pptx template screenshots and extract a style
# profile + per-page JSON Schema. Pick a provider you already trust -- there is
# no recommended default here, you must set this yourself.
#
# Examples (replace with your own endpoint and key; never paste random URLs):
#   VISION_BASE_URL=https://your-openai-compatible-relay.example.com/v1
#   VISION_API_KEY=sk-your-vision-key-here
#   VISION_MODEL_NAME=gemini-3.1-pro-preview   # or any vision-capable model
#
# Leave these unset to disable template-clone mode entirely.
VISION_BASE_URL=
VISION_API_KEY=
VISION_MODEL_NAME=
