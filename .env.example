# OpenAI 官方 Images API（也可以填任意 OpenAI 兼容中转站）
OPENAI_BASE_URL=https://api.openai.com
OPENAI_API_KEY=sk-your-key-here

# 模型名（默认 gpt-image-2）
GPT_IMAGE_MODEL_NAME=gpt-image-2

# 图片质量：low / medium / high / auto
GPT_IMAGE_QUALITY=high

# Vision 分析（独立 provider，OpenAI chat completions 兼容；可选，仅模板克隆功能用）
# 用于读取用户上传的 PPT 模板截图，提取风格描述。
VISION_BASE_URL=https://daydream88.fun/v1
VISION_API_KEY=sk-your-vision-key-here
VISION_MODEL_NAME=gemini-3.1-pro-preview
